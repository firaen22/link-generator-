{
    "version": 2,
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/[...path]"
        },
        {
            "src": "/s",
            "dest": "/api/[...path]"
        },
        {
            "src": "/s/(.*)",
            "dest": "/api/[...path]"
        },
        {
            "src": "/l/(.*)",
            "dest": "/api/[...path]"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}